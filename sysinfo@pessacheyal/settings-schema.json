{
    "layout": {
        "type": "layout",
        "pages": ["general", "sections", "graphs"],

        "general": {
            "type": "page",
            "title": "General",
            "sections": ["general-appearance", "general-clock"]
        },
        "general-appearance": {
            "type": "section",
            "title": "Appearance and refresh",
            "keys": ["refresh", "font-size", "theme-mode", "bg-opacity", "border-width", "border-color"]
        },
        "general-clock": {
            "type": "section",
            "title": "Time and date",
            "keys": ["clock-format"]
        },

        "sections": {
            "type": "page",
            "title": "Sections",
            "sections": ["sections-main", "sections-actions"]
        },
        "sections-main": {
            "type": "section",
            "title": "Sections to display",
            "keys": ["sections-list"]
        },
        "sections-actions": {
            "type": "section",
            "title": "Apply / cancel",
            "keys": ["sections-apply", "sections-reset"]
        },

        "graphs": {
            "type": "page",
            "title": "Graphs",
            "sections": ["graphs-main"]
        },
        "graphs-main": {
            "type": "section",
            "title": "History graphs",
            "keys": ["show-graphs", "graph-width", "graph-height", "graph-samples", "graph-color"]
        }
    },

    "refresh": {
        "type": "spinbutton",
        "default": 2, "min": 1, "max": 60, "step": 1,
        "units": "seconds",
        "description": "Refresh interval",
        "tooltip": "How often the metrics are re-read (seconds)"
    },
    "font-size": {
        "type": "spinbutton",
        "default": 12, "min": 9, "max": 24, "step": 1,
        "units": "px",
        "description": "Font size"
    },
    "theme-mode": {
        "type": "combobox",
        "default": "auto",
        "options": {
            "Auto (follow desktop)": "auto",
            "Dark": "dark",
            "Light": "light"
        },
        "description": "Theme"
    },
    "bg-opacity": {
        "type": "scale",
        "default": 65,
        "min": 0, "max": 100, "step": 1,
        "units": "%",
        "description": "Background opacity",
        "tooltip": "0 = fully transparent, 100 = fully opaque"
    },
    "border-width": {
        "type": "spinbutton",
        "default": 0, "min": 0, "max": 10, "step": 1,
        "units": "px",
        "description": "Border width",
        "tooltip": "Thickness of the outline around the desklet (0 = no border)"
    },
    "border-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,0.35)",
        "description": "Border color"
    },
    "clock-format": {
        "type": "entry",
        "default": "%H:%M:%S %d-%m-%Y",
        "description": "Time and date format",
        "tooltip": "strftime-style format string (e.g. %H:%M:%S %d-%m-%Y, %A %B %e, %I:%M %p, %F %T)"
    },

    "fetch-public-ip": {
        "type": "generic",
        "default": false
    },

    "sections-list": {
        "type": "list",
        "description": "Sections",
        "columns": [
            {
                "id": "section",
                "title": "Section",
                "type": "string",
                "default": "clock",
                "options": {
                    "Hostname":                "hostname",
                    "Time and date":           "clock",
                    "CPU + temperature":       "cpu",
                    "RAM":                     "mem",
                    "Swap":                    "swap",
                    "Disk usage":              "disk",
                    "Uptime":                  "uptime",
                    "Load average":            "loadavg",
                    "Battery":                 "battery",
                    "Network throughput":      "network",
                    "Network (per interface)": "network-ifaces",
                    "Local IP address":        "ip-local",
                    "Public IP address":       "ip-public",
                    "Custom text":             "text",
                    "Command output":          "command"
                }
            },
            {
                "id": "enabled",
                "title": "Show",
                "type": "boolean",
                "align": 0.5,
                "default": true
            },
            {
                "id": "label",
                "title": "Custom label",
                "type": "string",
                "default": ""
            },
            {
                "id": "command",
                "title": "Command (for Command rows)",
                "type": "string",
                "default": ""
            },
            {
                "id": "interval",
                "title": "Every (s)",
                "type": "integer",
                "default": 5,
                "min": 1,
                "max": 3600,
                "step": 1,
                "align": 0.5
            },
            {
                "id": "color",
                "title": "Color",
                "type": "string",
                "default": "",
                "options": {
                    "Theme default": "",
                    "White":         "#ffffff",
                    "Black":         "#000000",
                    "Red":           "#e5484d",
                    "Orange":        "#f76b15",
                    "Yellow":        "#ffcb47",
                    "Green":         "#30a46c",
                    "Cyan":          "#05a2c2",
                    "Blue":          "#3e63dd",
                    "Purple":        "#8e4ec6",
                    "Pink":          "#e93d82"
                }
            },
            {
                "id": "size",
                "title": "Size (px)",
                "type": "integer",
                "default": 0,
                "min": 0,
                "max": 72,
                "step": 1,
                "align": 0.5
            },
            {
                "id": "bold",
                "title": "Bold",
                "type": "boolean",
                "default": false,
                "align": 0.5
            },
            {
                "id": "italic",
                "title": "Italic",
                "type": "boolean",
                "default": false,
                "align": 0.5
            }
        ],
        "default": [
            { "section": "hostname",       "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": true,  "italic": false },
            { "section": "clock",          "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "cpu",            "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "mem",            "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "swap",           "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "disk",           "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "uptime",         "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "loadavg",        "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "battery",        "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "network",        "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "network-ifaces", "enabled": false, "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "ip-local",       "enabled": true,  "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false },
            { "section": "ip-public",      "enabled": false, "label": "", "command": "", "interval": 5, "color": "", "size": 0, "bold": false, "italic": false }
        ]
    },

    "sections-apply": {
        "type": "button",
        "description": "Apply changes now",
        "callback": "_onApplyClicked",
        "tooltip": "Force the desklet to re-render with the current section list. Changes normally apply automatically; use this if the desktop looks stale."
    },
    "sections-reset": {
        "type": "button",
        "description": "Reset sections to defaults",
        "callback": "_onResetClicked",
        "tooltip": "Restore the built-in section order, enabled state, labels, colors, sizes, and styles."
    },

    "show-graphs":   { "type": "checkbox", "default": true, "description": "Show sparkline graphs" },
    "graph-width":   {
        "type": "spinbutton",
        "default": 220, "min": 60, "max": 500, "step": 10,
        "units": "px",
        "description": "Graph width",
        "dependency": "show-graphs"
    },
    "graph-height":  {
        "type": "spinbutton",
        "default": 32, "min": 16, "max": 100, "step": 2,
        "units": "px",
        "description": "Graph height",
        "dependency": "show-graphs"
    },
    "graph-samples": {
        "type": "spinbutton",
        "default": 60, "min": 20, "max": 240, "step": 10,
        "description": "History length (samples)",
        "dependency": "show-graphs"
    },
    "graph-color": {
        "type": "colorchooser",
        "default": "rgba(98,160,234,1)",
        "description": "Graph line color",
        "dependency": "show-graphs"
    }
}
